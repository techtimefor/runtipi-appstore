{
  "schemaVersion": 2,
  "services": [
    {
      "name": "crafty",
      "image": "registry.gitlab.com/crafty-controller/crafty-4:4.10.4",
      "environment": [
        {
          "key": "TZ",
          "value": "${TZ}"
        }
      ],
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data/backups",
          "containerPath": "/crafty/backups",
          "readOnly": false,
          "shared": false,
          "private": false
        },
        {
          "hostPath": "${APP_DATA_DIR}/data/logs",
          "containerPath": "/crafty/logs",
          "readOnly": false,
          "shared": false,
          "private": false
        },
        {
          "hostPath": "${APP_DATA_DIR}/data/servers",
          "containerPath": "/crafty/servers",
          "readOnly": false,
          "shared": false,
          "private": false
        },
        {
          "hostPath": "${APP_DATA_DIR}/data/config",
          "containerPath": "/crafty/app/config",
          "readOnly": false,
          "shared": false,
          "private": false
        },
        {
          "hostPath": "${APP_DATA_DIR}/data/import",
          "containerPath": "/crafty/import",
          "readOnly": false,
          "shared": false,
          "private": false
        }
      ],
      "networkMode": "host",
      "isMain": true,
      "extraLabels": {
        "runtipi.managed": true
      }
    }
  ]
}
